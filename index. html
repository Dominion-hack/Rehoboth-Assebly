<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>REHOBOTH ASSEBLY</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Poppins', sans-serif;
}

body{
    background:url('https://images.unsplash.com/photo-1507692049790-de58290a4334') no-repeat center center/cover;
    min-height:100vh;
    color:#fff;
}

/* DARK OVERLAY */
.overlay{
    min-height:100vh;
    background:linear-gradient(to bottom, rgba(0,0,0,0.75), rgba(0,0,0,0.85));
    padding:20px;
}

/* NAV */
nav{
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:15px 30px;
    background:rgba(255,255,255,0.05);
    border:1px solid rgba(255,255,255,0.1);
    border-radius:15px;
    backdrop-filter:blur(10px);
}

nav h1{
    font-size:22px;
    font-weight:700;
    color:#ffd700;
}

nav a{
    color:#fff;
    text-decoration:none;
    margin:0 12px;
    font-size:15px;
    transition:0.3s;
}

nav a:hover{
    color:#ffd700;
}

/* HERO */
.hero{
    text-align:center;
    margin-top:90px;
    padding:20px;
    animation:fadeIn 1.5s ease-in-out;
}

.hero h2{
    font-size:50px;
    font-weight:700;
}

.hero p{
    max-width:800px;
    margin:15px auto;
    font-size:18px;
    line-height:1.8;
    opacity:0.9;
}

.btn{
    display:inline-block;
    margin-top:20px;
    padding:12px 25px;
    background:#ffd700;
    color:#000;
    font-weight:600;
    border-radius:30px;
    text-decoration:none;
    transition:0.3s;
}

.btn:hover{
    transform:scale(1.05);
}

/* SECTIONS */
.section{
    margin-top:80px;
    text-align:center;
}

.card{
    background:rgba(255,255,255,0.08);
    border:1px solid rgba(255,255,255,0.1);
    padding:30px;
    max-width:800px;
    margin:20px auto;
    border-radius:20px;
    backdrop-filter:blur(10px);
    transition:0.3s;
}

.card:hover{
    transform:translateY(-5px);
}

/* TITLES */
.section h2{
    font-size:32px;
    margin-bottom:10px;
    color:#ffd700;
}

.section p{
    font-size:17px;
    line-height:1.7;
    opacity:0.9;
}

/* FOOTER */
footer{
    text-align:center;
    margin-top:60px;
    padding:20px;
    font-size:14px;
    opacity:0.7;
}

/* ANIMATION */
@keyframes fadeIn{
    from{opacity:0; transform:translateY(20px);}
    to{opacity:1; transform:translateY(0);}
}

/* MOBILE */
@media(max-width:768px){
    .hero h2{font-size:32px;}
    nav{flex-direction:column;}
    nav a{display:inline-block; margin:8px;}
}
</style>
</head>

<body>

<div class="overlay">

<!-- NAV -->
<nav>
    <h1>REHOBOTH ASSEMBLY</h1>
    <div>
        <a href="#home">Home</a>
        <a href="#about">About</a>
        <a href="#service">Service</a>
        <a href="#contact">Contact</a>
    </div>
</nav>

<!-- HERO -->
<div class="hero" id="home">
    <h2>Welcome to Rehoboth Assembly</h2>
    <p>
        A place of worship, healing, and hope. Join us in growing your faith,
        discovering purpose, and experiencing God’s love every day.
    </p>

    <a class="btn" href="#service">Join Our Service</a>
</div>

<!-- ABOUT -->
<div class="section" id="about">
    <h2>About Us</h2>
    <div class="card">
        <p>
            We are a Christ-centered community focused on love, unity, and spiritual growth.
            Everyone is welcome — no matter your background.
        </p>
    </div>
</div>

<!-- SERVICE -->
<div class="section" id="service">
    <h2>Service Times</h2>
    <div class="card">
        <p>⛪ Sunday Worship — 9:00 AM</p>
        <p>📖 Bible Study — Wednesday 6:00 PM</p>
        <p>🙏 Prayer Night — Friday 7:00 PM</p>
    </div>
</div>

<!-- CONTACT -->
<div class="section" id="contact">
    <h2>Contact Us</h2>
    <div class="card">
        <p>📧 Email: rehobothassebly@gmail.com</p>
        <p>📞 Phone: +974 33843267</p>
        <p>📍 Location: AGLICAN CENTER,RELEGIOUS COMPLEX</p>
    </div>
</div>

<!-- FOOTER -->
<footer>
    © 2026 Grace Church. Built with faith ❤️
</footer>

</div>

</body>
</html>