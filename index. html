<!DOCTYPE html>
<html>
<head>
  <title>REHOBOTH ASSEMBLY DOHA</title>

  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      color: white;
    }

    /* HERO SECTION */
    .hero {
      background: url('https://repgyetdcodkynrbxocg.supabase.co/storage/v1/object/public/images/telegram-1777734751263-1c20463a.jpg') no-repeat center center/cover;
      height: 100vh;
      position: relative;
    }

    .overlay {
      background: rgba(0,0,0,0.6);
      height: 100%;
      padding: 20px;
    }

    header {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    header img {
      height: 50px;
    }

    nav a {
      color: white;
      margin: 10px;
      text-decoration: none;
      font-weight: bold;
    }

    .hero-content {
      text-align: center;
      margin-top: 100px;
    }

    /* SECTIONS */
    section {
      padding: 50px 20px;
      text-align: center;
    }

    .dark {
      background: #2c3e50;
    }

    .light {
      background: #ecf0f1;
      color: black;
    }

    /* PASTOR */
    .pastor img {
      width: 150px;
      border-radius: 50%;
    }

    /* GALLERY */
    .gallery img {
      width: 30%;
      margin: 5px;
      border-radius: 10px;
    }

    /* FORM */
    input, textarea {
      width: 80%;
      padding: 10px;
      margin: 10px;
    }

    button {
      padding: 10px 20px;
      background: #e67e22;
      border: none;
      color: white;
      cursor: pointer;
    }

    footer {
      background: #111;
      text-align: center;
      padding: 20px;
    }
  </style>
</head>

<body>

<!-- HERO -->
<div class="hero">
  <div class="overlay">

    <header>
      <!-- LOGO -->
      <img src="https://repgyetdcodkynrbxocg.supabase.co/storage/v1/object/public/images/telegram-1777734834676-de017e3c.jpg" alt="Church Logo">

      <nav>
        <a href="#">Home</a>
        <a href="#about">About</a>
        <a href="#pastor">Pastor</a>
        <a href="#contact">Contact</a>
      </nav>
    </header>

    <div class="hero-content">
      <h1>WELCOME TO REHOBOTH ASSEMBLY QATAR</h1>
      <p>Join us every Sunday at 9AM</p>
    </div>

  </div>
</div>

<!-- ABOUT -->
<section id="about" class="light">
  <h2>Our Mission</h2>
  <p>We are committed to spreading love, faith, and hope in our community.</p>
</section>

<!-- PASTOR -->
<section id="pastor" class="dark pastor">
  <h2>Meet Our Pastor</h2>
  <img src="PASTOR-IMAGE-URL">
  <p>Pastor Adekunle is dedicated to serving God and guiding our church.</p>
</section>

<!-- GALLERY -->
<section class="light gallery">
  <h2>Church Moments</h2>
  <img src="https://repgyetdcodkynrbxocg.supabase.co/storage/v1/object/public/images/telegram-1777735475925-5a69d99a.jpg">
  <img src="https://repgyetdcodkynrbxocg.supabase.co/storage/v1/object/public/images/telegram-1777735528624-269fbac2.jpg">
  <img src="https://repgyetdcodkynrbxocg.supabase.co/storage/v1/object/public/images/telegram-1777735561008-424a2e0f.jpg">
</section>



<section id="contact" class="dark">

  <h2>Contact us & Prayer Request</h2>

  <form>
    <input type="text" placeholder="Your Name"><br>
    <input type="email" placeholder="Your Email"><br>
    <textarea placeholder="Your Message"></textarea><br>
    <button>Send</button>
  </form>

  <h3>Find Us Here</h3>

  <iframe 
    src="https://www.google.com/maps?q=Religious Complex&output=embed"
    width="90%" 
    height="300" 
    style="border:0; border-radius:10px;" 
    loading="lazy">
  </iframe>

</section>
</section>

<footer>
  <p>© 2026 REHOBOTH ASSEMBLY QATAR| All Rights Reserved</p>
</footer>

</body>
</html>